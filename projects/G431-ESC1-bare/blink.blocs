# blink.blocs - blink the onboard LED (PC06) at 1Hz
# Uses a not block as a toggle, feedback loop creates oscillation

search $EMBLOCS/src/components

blockdef portC_gpio stm32_gpio  PORT_NUM=2 INPUTS=0  OUTPUTS=0x00000040  ENABLES=0
blockdef not_block  not

block portC portC_gpio
block tog   not_block

signal state  bool  +tog.out  +tog.in  +portC.pin06_out

thread init   1          +portC.init
thread blink  500000000  +tog.update  +portC.write
